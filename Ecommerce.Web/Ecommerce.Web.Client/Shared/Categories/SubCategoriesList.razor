 @page "/subcategories/{ParentCategoryId:int}"
@rendermode InteractiveWebAssembly
<div>
    <div class="container">
        <div id="gfg" class="modal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-body">
                        <p>
                           @foreach(var product in Products )
                            {
                                <button @onclick="()=>{GetOutProduct(product.Id);}"><b>@product.Name</b></button>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <h1 class="product_taital"></h1>
                <p class="product_text">incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation</p>
            </div>
        </div>
        <div class="product_section_2 layout_padding">
            <div class="row">
                @foreach (var subCategory in SubCategories)
                {
                    <div class="col-lg-12 col-sm-6">
                        <div class="product_box">
                            <button style="margin-left:487px" class="btn btn-success" @onclick="async()=> {await ToggleModal1(subCategory.Id);}">
                                @subCategory.Name
                            </button>
                            <p class="lorem_text">@subCategory</p>
                            <img src="" class="image_1">
                            <button class="btn-btn-primary">Explore</button>
                        </div>
                    </div>
                }
            </div>
            <div class="seemore_bt"><a href="#">See More</a></div>
        </div>
    </div>
</div> 




